{
  "name": "network_v1",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "setup-venv": "python -m venv venv",
    "install-python": "node scripts/install-python-deps.mjs",
    "fastapi-dev": "npm run install-python && node scripts/run-uvicorn.mjs api.index:app --reload",
    "fastapi-start": "node scripts/run-uvicorn.mjs api.index:app --host 127.0.0.1 --port 8000",
    "next-dev": "next dev",
    "dev": "concurrently \"npm run next-dev\" \"npm run fastapi-dev\"",
    "build": "next build && npm run install-python",
    "start": "next start",
    "railway-start": "npm run install-python && node scripts/start-production.mjs",
    "build-docs-index": "npm run install-python && node scripts/build-docs-index.mjs",
    "validate-docs-index": "npm run install-python && node scripts/validate-docs-index.mjs",
    "lint": "eslint",
    "dev:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "next": "^16.0.10",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
