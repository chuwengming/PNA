# 環境變數範本（可提交 Git）
#
# 本機建議：
#   1. 複製為 .env          → DATABASE_URL + RAG 設定（FastAPI 讀取）
#   2. 複製 .env.local.example 為 .env.local → AUTH / Google OAuth（Next.js）
#   3. 本機建索引：npm run build-docs-index
#   4. 將 docs/index/chunks.json 提交 Git，Railway 部署時一併帶上
#   5. 執行：npm run dev  或  npm run dev:local
#
# Railway：在 App 服務 Variables 設定 GEMINI_API_KEY 等（不必用檔案）

# --- .env（MySQL，FastAPI 會讀）---
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE
# 或 Railway 提供的別名：
# MYSQL_URL=mysql://...

# --- .env.local（NextAuth / OAuth，Next.js 會讀）---
AUTH_SECRET=
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PYTHON_API_URL=http://127.0.0.1:8000

# --- Docs RAG：嵌入（sentence-transformers，本機/Railway 通用）---
# 預設多語言模型，支援繁中與其他語言
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
# LOCAL_EMBED_BATCH_SIZE=32

# --- Docs RAG：回答生成 ---
# gemini（預設，每次提問 1 次 API）| ollama（本機免費，需 ollama serve）
GENERATION_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
# GEMINI_GENERATION_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-1.5-flash
# GENERATION_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_GENERATION_MODEL=llama3.2

# RAG 參數（可選）
# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=150
# RAG_TOP_K=8
# RAG_MAX_CONTEXT_CHARS=10000
# RAG_MIN_CONTEXT_CHUNKS=3
# RAG_WEB_SEARCH_ENABLED=true
# RAG_WEB_SEARCH_MAX_RESULTS=3
# RAG_WEB_SEARCH_MAX_CHARS=2000
