# 環境變數範本（可提交 Git）
#
# 本機建議：
#   1. 複製為 .env          → 只放 DATABASE_URL（給 FastAPI / python-dotenv）
#   2. 複製 .env.local.example 為 .env.local → AUTH / Google OAuth（給 Next.js）
#   3. 執行：npm run dev  或  npm run dev:local
#
# Railway：在 App 服務 Variables 設定下列變數（不必用檔案）

# --- .env（MySQL，FastAPI 會讀）---
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE
# 或 Railway 提供的別名：
# MYSQL_URL=mysql://...

# --- .env.local（NextAuth / OAuth，Next.js 會讀）---
AUTH_SECRET=
# 本機：
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Railway（改成瀏覽器實際開啟的網址，不要用 IP，建議用 https://你的服務.up.railway.app）：
# AUTH_URL=https://你的服務.up.railway.app
# NEXTAUTH_URL=https://你的服務.up.railway.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 本機與 Railway（同容器內 FastAPI）：
PYTHON_API_URL=http://127.0.0.1:8000
