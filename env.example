# 複製為 .env.local（本機）或在 Railway「Variables」設定同名變數。
# 請勿將含真實密碼的檔案提交到 Git。

# MySQL（擇一）：完整 URL（Railway MySQL 面板常見）
# DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE

# 若 Railway 只提供公開 Proxy URL，也可能叫 MYSQL_PUBLIC_URL —— 程式會自動讀取。
# MYSQL_PUBLIC_URL=mysql://...

AUTH_SECRET=
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Next.js 將 /api/python/* rewrite 到此（本機 FastAPI）
PYTHON_API_URL=http://127.0.0.1:8000
